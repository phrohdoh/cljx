#exec  2> >(tee -ia "${script_stem}.log" >&2)
## 19 is arbitrary but must be an unallocated file descriptor
#exec 19> "${script_stem}.log"
#export BASH_XTRACEFD=19

pushd "$root_dir" 1>/dev/null
#set -x
main "${@}"
ret=$?
#set +x
popd 1>/dev/null || {}
exit $ret
